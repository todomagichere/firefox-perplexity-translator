{
  "manifest_version": 2,
  "name": "Perplexity Selection Translator",
  "version": "1.2.2",
  "description": "Traduce texto seleccionado usando Perplexity en una ventana emergente.",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab"
  ],
  "background": {
    "scripts": [
      "i18n.js",
      "background.js"
    ]
  },
  "browser_action": {
    "default_title": "Perplexity Translator",
    "default_popup": "settings.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "{fb45bbef-f530-475a-b296-c43657c536e3}"
    }
  }
}

