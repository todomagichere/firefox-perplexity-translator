{
  "manifest_version": 2,
  "name": "Perplexity Selection Translator",
  "version": "1.2.0",
  "description": "Traduce texto seleccionado usando Perplexity en una ventana emergente.",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab"
  ],
  "background": {
    "scripts": [
      "i18n.js",
      "background.js"
    ]
  },
  "browser_action": {
    "default_title": "Perplexity Translator",
    "default_popup": "settings.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "perplexity-selection-translator@example.com"
    }
  }
}
